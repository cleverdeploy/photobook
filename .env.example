# Copy to .env for local dev (do NOT commit .env). In production these are set
# in the Dokploy service's Environment tab.

# Owner login password (the only account). Pick something strong.
OWNER_PASSWORD=changeme

# Signs session cookies. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-secret-change-me

# Public base URL — used for absolute share links + WhatsApp/OG previews.
BASE_URL=http://localhost:8080

# Anthropic key for AI theming. If empty, a deterministic fallback theme is used.
ANTHROPIC_API_KEY=

# Where the SQLite DB + photos are stored. In Docker this is the /data volume.
DATA_DIR=./data
